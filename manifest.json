{
  "manifest_version": 3,
  "name": "Brave History Manager",
  "version": "1.1",
  "description": "Selectively manage browser history for specific domains",
  "permissions": [
    "history",
    "storage",
    "tabs",
    "scripting",
    "browsingData",
    "cookies"
  ],
  "host_permissions": [
    "*://reddit.com/*",
    "*://www.reddit.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}